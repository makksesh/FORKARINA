@model IEnumerable<LibApp.Models.VersionBook>

@{
    ViewData["Title"] = "Издания";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h3 class="fw-bold mb-0" style="color: var(--blue-dk);">🖨️ Издания книг</h3>
        <span class="text-muted small">Версии и тиражи произведений</span>
    </div>
    <a asp-action="Create" class="btn btn-success btn-sm">+ Добавить</a>
</div>

@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        ⚠️ @ViewBag.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">Издания не найдены.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle shadow-sm rounded overflow-hidden">
            <thead style="background: var(--blue-dk); color:#fff;">
                <tr>
                    <th>ID</th>
                    <th>@Html.DisplayNameFor(m => m.Name)</th>
                    <th>@Html.DisplayNameFor(m => m.Book)</th>
                    <th>@Html.DisplayNameFor(m => m.Publisher)</th>
                    <th>@Html.DisplayNameFor(m => m.CreateAt)</th>
                    <th>@Html.DisplayNameFor(m => m.CountSheets)</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-muted font-monospace">@item.VersionBookId</td>
                        <td class="fw-semibold">@item.Name</td>
                        <td>@item.Book?.Name</td>
                        <td class="text-muted small">@item.Publisher?.Name</td>
                        <td class="text-muted small">@item.CreateAt.ToString("dd.MM.yyyy")</td>
                        <td>
                            <span class="badge bg-light text-dark border">
                                @item.CountSheets стр.
                            </span>
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-action="Details" asp-route-id="@item.VersionBookId"
                                   class="btn btn-outline-secondary btn-sm">🔍</a>
                                <a asp-action="Edit" asp-route-id="@item.VersionBookId"
                                   class="btn btn-outline-primary btn-sm">✏️</a>
                                <a asp-action="Delete" asp-route-id="@item.VersionBookId"
                                   class="btn btn-outline-danger btn-sm">🗑️</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
