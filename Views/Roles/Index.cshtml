@model IEnumerable<LibApp.Models.Role>

@{
    ViewData["Title"] = "Роли";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h3 class="fw-bold mb-0" style="color: var(--blue-dk);">🔐 Роли</h3>
        <span class="text-muted small">Уровни доступа пользователей системы</span>
    </div>
    <a asp-action="Create" class="btn btn-success btn-sm">+ Добавить</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Роли не найдены.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle shadow-sm rounded overflow-hidden">
            <thead style="background: var(--blue-dk); color:#fff;">
                <tr>
                    <th>ID</th>
                    <th>@Html.DisplayNameFor(m => m.Name)</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var badge = item.Name switch
                    {
                        "Admin"     => ("danger",  "🔴"),
                        "Librarian" => ("primary", "🔵"),
                        "Reader"    => ("success", "🟢"),
                        _           => ("secondary","⚪")
                    };
                    <tr>
                        <td class="text-muted font-monospace">@item.RoleId</td>
                        <td>
                            <span class="badge bg-@badge.Item1 fs-6">
                                @badge.Item2 @item.Name
                            </span>
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-action="Details" asp-route-id="@item.RoleId"
                                   class="btn btn-outline-secondary btn-sm">🔍</a>
                                <a asp-action="Edit" asp-route-id="@item.RoleId"
                                   class="btn btn-outline-primary btn-sm">✏️</a>
                                <a asp-action="Delete" asp-route-id="@item.RoleId"
                                   class="btn btn-outline-danger btn-sm">🗑️</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
