@model IEnumerable<LibApp.Models.Category>

@{
    ViewData["Title"] = "Жанры";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h3 class="fw-bold mb-0" style="color: var(--blue-dk);">🏷️ Жанры</h3>
        <span class="text-muted small">Классификация книжного фонда</span>
    </div>
    <a asp-action="Create" class="btn btn-success btn-sm">+ Добавить</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Жанры не найдены.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle shadow-sm rounded overflow-hidden">
            <thead style="background: var(--blue-dk); color:#fff;">
                <tr>
                    <th>ID</th>
                    <th>@Html.DisplayNameFor(m => m.Name)</th>
                    <th>@Html.DisplayNameFor(m => m.Description)</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-muted font-monospace">@item.CategoryId</td>
                        <td class="fw-semibold">@item.Name</td>
                        <td class="text-muted small">
                            @if (!string.IsNullOrEmpty(item.Description))
                            {
                                @(item.Description.Length > 80
                                    ? item.Description[..80] + "…"
                                    : item.Description)
                            }
                            else { <span>—</span> }
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-action="Details" asp-route-id="@item.CategoryId"
                                   class="btn btn-outline-secondary btn-sm">🔍</a>
                                <a asp-action="Edit" asp-route-id="@item.CategoryId"
                                   class="btn btn-outline-primary btn-sm">✏️</a>
                                <a asp-action="Delete" asp-route-id="@item.CategoryId"
                                   class="btn btn-outline-danger btn-sm">🗑️</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
