@model LibApp.Models.ExampleBook
@using LibApp.Models

@{
    ViewData["Title"] = "Редактирование экземпляра";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h3 class="fw-bold mb-0" style="color: var(--blue-dk);">✏️ Редактирование экземпляра</h3>
        <span class="text-muted small font-monospace">ID: @Model.ExampleBookId</span>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Назад к списку</a>
</div>

<div class="card shadow-sm" style="max-width: 560px;">
    <div class="card-body">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>
            <input type="hidden" asp-for="ExampleBookId" />

            <div class="mb-3">
                <label asp-for="VersionBookId" class="form-label fw-semibold"></label>
                <select asp-for="VersionBookId" class="form-select" asp-items="ViewBag.VersionBookId">
                    <option value="">— Выберите издание —</option>
                </select>
                <span asp-validation-for="VersionBookId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ShelfCode" class="form-label fw-semibold"></label>
                <input asp-for="ShelfCode" class="form-control font-monospace"
                       placeholder="Например: A-03-2" />
                <span asp-validation-for="ShelfCode" class="text-danger small"></span>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-6">
                    <label asp-for="Status" class="form-label fw-semibold"></label>
                    <select asp-for="Status" class="form-select"
                            asp-items="Html.GetEnumSelectList<BookStatus>()"></select>
                    <span asp-validation-for="Status" class="text-danger small"></span>
                </div>
                <div class="col-6">
                    <label asp-for="Condition" class="form-label fw-semibold"></label>
                    <select asp-for="Condition" class="form-select"
                            asp-items="Html.GetEnumSelectList<BookCondition>()"></select>
                    <span asp-validation-for="Condition" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100">💾 Сохранить</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
