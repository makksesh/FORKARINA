@model LibApp.Models.Fine

@{
    ViewData["Title"] = "Create";
}

<h1>Создание</h1>

<h4>Штраф</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="ReaderId" class="control-label"></label>
                <select asp-for="ReaderId" class ="form-control" asp-items="ViewBag.ReaderId"></select>
            </div>
            <div class="form-group">
                <label asp-for="LibrarianId" class="control-label"></label>
                <select asp-for="LibrarianId" class ="form-control" asp-items="ViewBag.LibrarianId"></select>
            </div>
            <div class="form-group">
                <label asp-for="Amount" class="control-label"></label>
                <input asp-for="Amount" class="form-control" />
                <span asp-validation-for="Amount" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="IssuedAt" class="control-label"></label>
                <input asp-for="IssuedAt" class="form-control" />
                <span asp-validation-for="IssuedAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PaidAt" class="control-label"></label>
                <input asp-for="PaidAt" class="form-control" />
                <span asp-validation-for="PaidAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Reason" class="control-label"></label>
                <input asp-for="Reason" class="form-control" />
                <span asp-validation-for="Reason" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Создать" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Вернуться к списку</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
