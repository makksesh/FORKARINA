@model LibApp.Models.ViewModels.ReturnBookViewModel
@{
    ViewData["Title"] = "Приём книги";
    var loan = Model.Loan;
    var book = loan.ExampleBook?.VersionBook?.Book;
    var author = book?.Author;
    var publisher = loan.ExampleBook?.VersionBook?.Publisher;
}

<div class="container mt-4" style="max-width: 680px;">
    <h4 class="mb-4">📚 Приём книги</h4>

    @* Карточка выдачи *@
    <div class="card mb-4 @(Model.IsOverdue ? "border-warning" : "border-success")"
         style="@(Model.IsOverdue ? "background-color: #fffbe6;" : "")">
        <div class="card-header d-flex justify-content-between align-items-center
                    @(Model.IsOverdue ? "bg-warning text-dark" : "bg-success text-white")">
            <span><strong>Информация о выдаче #@loan.LoanId</strong></span>
            @if (Model.IsOverdue)
            {
                <span class="badge bg-dark">⚠️ Просрочено на @Model.OverdueDays дн.</span>
            }
            else
            {
                <span class="badge bg-light text-success">✅ В срок</span>
            }
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-4">Книга</dt>
                <dd class="col-sm-8">@(book?.Name ?? "—")</dd>
                <dt class="col-sm-4">Автор</dt>
                <dd class="col-sm-8">@(author?.FullName ?? "—")</dd>
                <dt class="col-sm-4">Издательство</dt>
                <dd class="col-sm-8">@(publisher?.Name ?? "—")</dd>
                <dt class="col-sm-4">Читатель</dt>
                <dd class="col-sm-8">@loan.User?.FullName (@loan.User?.Email)</dd>
                <dt class="col-sm-4">Выдана</dt>
                <dd class="col-sm-8">@loan.IssuedAt.ToLocalTime().ToString("dd.MM.yyyy")</dd>
                <dt class="col-sm-4">Срок возврата</dt>
                <dd class="col-sm-8 @(Model.IsOverdue ? "text-danger fw-bold" : "")">
                    @loan.DueDate.ToLocalTime().ToString("dd.MM.yyyy")
                    @if (Model.IsOverdue)
                    {
                        <span class="ms-2 text-danger">(просрочено на @Model.OverdueDays дн.)</span>
                    }
                </dd>
            </dl>
        </div>
    </div>

    @* === ЕДИНАЯ ФОРМА === *@
    <form asp-action="ReturnBook" asp-controller="ReturnBook" method="post" id="mainForm">
        @Html.AntiForgeryToken()
        <input type="hidden" name="loanId" value="@loan.LoanId" />

        @* Блок просрочки — без кнопки *@
        @if (Model.IsOverdue)
        {
            <div class="card border-danger mb-4">
                <div class="card-header bg-danger text-white">
                    <strong>💰 Штраф за просрочку</strong>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Цена за 1 просроченный день (₽)</label>
                        <input type="number" id="pricePerDay" name="pricePerDay"
                               class="form-control" min="0.01" step="0.01"
                               placeholder="Например: 10.00"
                               oninput="calcFine()" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Количество просроченных дней</label>
                        <input type="text" class="form-control bg-light"
                               value="@Model.OverdueDays" readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Итого штраф за просрочку (₽)</label>
                        <input type="text" id="totalFine"
                               class="form-control bg-warning fw-bold"
                               value="0.00" readonly />
                    </div>
                </div>
            </div>
        }

        @* Блок повреждения — всегда виден *@
        <div class="card border-warning mb-4">
            <div class="card-header bg-warning text-dark">
                <strong>🔍 Состояние книги при возврате</strong>
            </div>
            <div class="card-body">
                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" id="isDamaged"
                           name="isDamaged" value="true"
                           onchange="toggleDamageBlock(); updateSubmitButton()" />
                    <label class="form-check-label fw-bold text-danger" for="isDamaged">
                        Книга возвращена с повреждениями
                    </label>
                </div>

                <div id="damageBlock" style="display:none;">
                    <div class="mb-3">
                        <label class="form-label">Новое состояние книги</label>
                        <select name="newCondition" class="form-select">
                            <option value="Fair">Удовлетворительное</option>
                            <option value="Poor">Плохое</option>
                            <option value="Damaged">Повреждена</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Комментарий к повреждению</label>
                        <textarea name="damageComment" class="form-control" rows="2"
                                  placeholder="Опишите повреждение: порваны страницы, следы воды и т.п."></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Штраф за повреждение (₽)</label>
                        <input type="number" name="damageFineAmount" class="form-control"
                               min="0" step="0.01" placeholder="0.00" />
                        <div class="form-text">Оставьте 0, если штраф не начисляется</div>
                    </div>
                </div>
            </div>
        </div>

        @* === ЕДИНАЯ КНОПКА === *@
        <div class="d-grid gap-2">
            @* Кнопка со штрафом — активна если просрочка ИЛИ повреждение *@
            <button type="submit" id="btnWithFine"
                    class="btn btn-danger w-100"
                    @(Model.IsOverdue ? "" : "disabled")>
                💳 Внести штраф и принять книгу
            </button>

            @* Кнопка без штрафа — всегда активна *@
            <button type="submit" id="btnWithoutFine"
                    name="skipFine" value="true"
                    class="btn btn-outline-secondary w-100">
                ✅ Принять книгу без штрафа
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        const isOverdue = @Json.Serialize(Model.IsOverdue);

        function calcFine() {
            const price = parseFloat(document.getElementById('pricePerDay')?.value) || 0;
            const days = @Model.OverdueDays;
            document.getElementById('totalFine').value = (price * days).toFixed(2);
        }

        function toggleDamageBlock() {
            const checked = document.getElementById('isDamaged').checked;
            document.getElementById('damageBlock').style.display = checked ? 'block' : 'none';
        }

        function updateSubmitButton() {
            const isDamaged = document.getElementById('isDamaged').checked;
            const btn = document.getElementById('btnWithFine');
            // Активна если: есть просрочка ИЛИ отмечено повреждение
            btn.disabled = !(isOverdue || isDamaged);
        }
    </script>
}
